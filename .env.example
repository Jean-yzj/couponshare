# ─────────────────────────── CouponShare env ───────────────────────────
# Copy to .env and fill in. Required vars are validated at boot in production
# (see instrumentation.ts); feature vars silently disable their feature if unset.

# ── Required (production refuses to boot without these) ──────────────────
# PostgreSQL connection string.
DATABASE_URL="postgresql://user:password@localhost:5432/couponshare"
# Secret used to HMAC-sign session cookies and barcode-access tokens. Use a long
# random string (e.g. `openssl rand -base64 48`). Rotating it logs everyone out.
SESSION_SECRET=""
# Secret for AES-256-GCM barcode/redeem-code encryption. MUST be identical wherever
# barcodes are encrypted (seeding) and decrypted (the running app), or every
# barcode fails to decrypt. Changing it makes all existing barcodes unreadable.
BARCODE_KEY=""

# ── Admin ────────────────────────────────────────────────────────────────
# Comma-separated list of admin emails. Unset ⇒ nobody can reach the admin
# dashboard / stats. Required in practice.
ADMIN_EMAILS=""

# ── Public origin / OAuth redirects ──────────────────────────────────────
# Canonical public URL. Used for sitemap/robots/OG tags and OAuth redirect URIs.
# Defaults to https://couponshare.lazybearlife.com if unset.
APP_ORIGIN="http://localhost:3000"

# ── Google OAuth (web) — unset disables Google login ─────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Google Sign-In audience for the native iOS app (id_token verification).
GOOGLE_IOS_CLIENT_ID=""

# ── Apple Sign-In (native) — unset disables Apple login ──────────────────
APPLE_BUNDLE_ID=""

# ── Background jobs ──────────────────────────────────────────────────────
# Shared secret for the external HTTP cron routes (x-cron-secret header). In
# production the cron routes fail closed if unset. The in-process scheduler
# (instrumentation.ts) does not need it.
CRON_SECRET=""
# Set to "1" to disable the in-process scheduler (e.g. on all-but-one instance
# in a multi-instance deploy, relying on the external cron routes instead).
DISABLE_CRON=""

# ── Database backup endpoint ─────────────────────────────────────────────
# Secret for GET /api/v1/admin/backup (Bearer). Required for backups to work.
BACKUP_SECRET=""
