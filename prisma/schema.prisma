// CouponShare — Prisma schema
// Faithful to PRD v1.1 §6. Camel-case fields map to snake_case columns.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────── Enums ───────────────────────────

enum LoginProvider {
  EMAIL
  GOOGLE
  APPLE
  LINE
  ANONYMOUS
}

enum UserLevel {
  LEVEL_1
  LEVEL_2
  LEVEL_3
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

// Shared by coupon.type, claim_request.request_type, transaction.transaction_type
enum CouponType {
  GIFT
  EXCHANGE
}

enum CouponCategory {
  CONVENIENCE
  COFFEE
  DRINK
  FASTFOOD
  DESSERT
  RESTAURANT
  SHOPPING
  ENTERTAINMENT
  OTHER
}

// What the coupon actually gives: a free item to redeem, or money off.
enum CouponRedeemKind {
  FREE_ITEM
  DISCOUNT
}

enum CouponStatus {
  DRAFT
  AVAILABLE
  PENDING
  CLAIMED
  EXPIRED
  CANCELLED
  REPORTED
  SUSPENDED
}

enum UnlockPolicy {
  OWNER_APPROVAL
  AUTO_REVEAL_AFTER_MESSAGE
}

enum VisibilityLevel {
  PUBLIC
  LEVEL_2_ONLY
  LEVEL_3_ONLY
}

enum ClaimRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
  EXPIRED
}

enum TransactionStatus {
  CREATED
  COMPLETED
  DISPUTED
  CANCELLED
}

enum ReportReason {
  INVALID_COUPON
  EXPIRED_COUPON
  ALREADY_USED
  UNREASONABLE_EXCHANGE
  NO_RESPONSE
  ABUSIVE_MESSAGE
  SCAM
  OTHER
}

enum ReportStatus {
  PENDING
  REVIEWING
  RESOLVED
  REJECTED
}

enum ScoreEventType {
  COUPON_GIFTED
  COUPON_EXCHANGED
  THANK_YOU_MESSAGE
  POSITIVE_RATING
  SOCIAL_POST_APPROVED
  COUPON_WITHDRAWN
  INVALID_COUPON_REPORT_CONFIRMED
  NO_SHOW_REPORT_CONFIRMED
  ADMIN_ADJUSTMENT
}

enum ScoreReferenceType {
  COUPON
  TRANSACTION
  REPORT
  ADMIN
}

enum NotificationType {
  CLAIM_REQUEST_RECEIVED
  CLAIM_APPROVED
  CLAIM_REJECTED
  COUPON_EXPIRING_SOON
  COUPON_EXPIRED
  TRANSACTION_COMPLETED
  TRANSACTION_MESSAGE
  RATING_RECEIVED
  REPORT_UPDATED
  BRAND_RESTOCK
  APPEAL_UPDATED
  SOCIAL_POST_UPDATED
  BUSINESS_LEAD_RECEIVED
}

enum AppealStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum SocialPostStatus {
  PENDING
  APPROVED
  REJECTED
}

// ─────────────────────────── Models ───────────────────────────

model User {
  id                String        @id @default(uuid())
  displayName       String        @map("display_name")
  avatarUrl         String?       @map("avatar_url")
  email             String?       @unique
  passwordHash      String?       @map("password_hash")
  appleSub          String?       @unique @map("apple_sub")
  phone             String?
  loginProvider     LoginProvider @default(EMAIL) @map("login_provider")
  deviceId          String?       @map("device_id")
  contributionScore Int           @default(0) @map("contribution_score")
  userLevel         UserLevel     @default(LEVEL_1) @map("user_level")
  riskFlag          Boolean       @default(false) @map("risk_flag")
  status            UserStatus    @default(ACTIVE)
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")
  lastLoginAt       DateTime?     @map("last_login_at")
  birthYear         Int?          @map("birth_year")
  utmSource         String?       @map("utm_source")
  utmMedium         String?       @map("utm_medium")
  utmCampaign       String?       @map("utm_campaign")
  utmContent        String?       @map("utm_content")
  utmTerm           String?       @map("utm_term")
  landingPath       String?       @map("landing_path")
  // Who invited this user (their user id). Plain scalar — we only ever count
  // "signups referred by X" for the invite bonus, no relation needed.
  referredById      String?       @map("referred_by_id")
  // Monthly bonus-claim pool (社群發文審核通過 +10/+20、推薦成功 +2). Scoped to a
  // Taipei calendar month via bonusClaimsMonth ("2026-07"); a stale month reads 0.
  bonusClaims       Int           @default(0) @map("bonus_claims")
  bonusClaimsMonth  String?       @map("bonus_claims_month")
  // Activity tracking: updated on every authenticated request (3-min throttle).
  lastSeenAt        DateTime?     @map("last_seen_at")

  ownedCoupons         Coupon[]             @relation("OwnedCoupons")
  claimedCoupons       Coupon[]             @relation("ClaimedCoupons")
  claimRequests        ClaimRequest[]
  ownerTransactions    Transaction[]        @relation("OwnerTransactions")
  claimantTransactions Transaction[]        @relation("ClaimantTransactions")
  sentMessages         TransactionMessage[]
  ratingsGiven         Rating[]             @relation("RatingsGiven")
  ratingsReceived      Rating[]             @relation("RatingsReceived")
  reportsMade          Report[]             @relation("ReportsMade")
  reportsAgainst       Report[]             @relation("ReportsAgainst")
  scoreLedgers         ScoreLedger[]
  notifications        Notification[]
  brandFollows         BrandFollow[]
  appeals              Appeal[]
  socialPosts          SocialPost[]
  pushTokens           PushToken[]
  blocksMade           Block[]              @relation("BlocksMade")
  blocksReceived       Block[]              @relation("BlocksReceived")
  dailyActives         DailyActive[]

  @@index([referredById, createdAt])
  @@index([birthYear])
  @@index([utmSource, createdAt])
  @@index([utmCampaign, createdAt])
  @@index([lastSeenAt])
  @@map("users")
}

model PushToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  platform  String
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("push_tokens")
}

model Block {
  id        String   @id @default(uuid())
  blockerId String   @map("blocker_id")
  blockedId String   @map("blocked_id")
  createdAt DateTime @default(now()) @map("created_at")

  blocker User @relation("BlocksMade", fields: [blockerId], references: [id])
  blocked User @relation("BlocksReceived", fields: [blockedId], references: [id])

  @@unique([blockerId, blockedId])
  @@index([blockedId])
  @@map("blocks")
}

model Coupon {
  id                   String          @id @default(uuid())
  ownerId              String          @map("owner_id")
  title                String
  brand                String
  description          String?
  expiryDate           DateTime?       @map("expiry_date")
  type                 CouponType
  category             CouponCategory  @default(OTHER)
  exchangeTarget       String?         @map("exchange_target")
  status               CouponStatus    @default(DRAFT)
  claimantId           String?         @map("claimant_id")
  barcodeEncryptedData String?         @map("barcode_encrypted_data")
  barcodeMime          String?         @map("barcode_mime")
  barcodeImageUrl      String?         @map("barcode_image_url")
  barcodeStorageKey    String?         @map("barcode_storage_key")
  // Redeem via a text code instead of / as well as a barcode image (AES-encrypted,
  // shown only to the chosen claimant — same secrecy as the barcode).
  redeemCodeEncrypted  String?         @map("redeem_code_encrypted")
  // FREE_ITEM = redeem a free product; DISCOUNT = money/percent off. Nullable for
  // coupons created before this field existed.
  redeemKind           CouponRedeemKind? @map("redeem_kind")
  unlockPolicy         UnlockPolicy    @default(OWNER_APPROVAL) @map("unlock_policy")
  visibilityLevel      VisibilityLevel @default(PUBLIC) @map("visibility_level")
  viewCount            Int             @default(0) @map("view_count")
  claimRequestCount    Int             @default(0) @map("claim_request_count")
  reportCount          Int             @default(0) @map("report_count")
  claimedAt            DateTime?       @map("claimed_at")
  cancelledAt          DateTime?       @map("cancelled_at")
  createdAt            DateTime        @default(now()) @map("created_at")
  updatedAt            DateTime        @updatedAt @map("updated_at")

  owner         User           @relation("OwnedCoupons", fields: [ownerId], references: [id])
  claimant      User?          @relation("ClaimedCoupons", fields: [claimantId], references: [id])
  claimRequests ClaimRequest[]
  transactions  Transaction[]
  reports       Report[]

  @@index([ownerId])
  @@index([status])
  @@index([brand])
  @@index([type])
  @@index([category])
  @@index([expiryDate])
  @@index([createdAt])
  @@index([status, createdAt])
  @@index([status, expiryDate])
  @@index([status, claimRequestCount])
  @@index([status, visibilityLevel, expiryDate])
  @@index([status, brand, createdAt])
  @@map("coupons")
}

model ClaimRequest {
  id                    String             @id @default(uuid())
  couponId              String             @map("coupon_id")
  requesterId           String             @map("requester_id")
  requestType           CouponType         @map("request_type")
  message               String
  exchangeOfferText     String?            @map("exchange_offer_text")
  exchangeOfferImageUrl String?            @map("exchange_offer_image_url")
  status                ClaimRequestStatus @default(PENDING)
  ownerResponseMessage  String?            @map("owner_response_message")
  createdAt             DateTime           @default(now()) @map("created_at")
  updatedAt             DateTime           @updatedAt @map("updated_at")
  approvedAt            DateTime?          @map("approved_at")
  rejectedAt            DateTime?          @map("rejected_at")

  coupon       Coupon        @relation(fields: [couponId], references: [id])
  requester    User          @relation(fields: [requesterId], references: [id])
  transactions Transaction[]

  @@unique([couponId, requesterId])
  @@index([couponId])
  @@index([requesterId])
  @@index([status])
  @@index([couponId, status])
  @@index([createdAt])
  @@map("claim_requests")
}

model Transaction {
  id              String            @id @default(uuid())
  couponId        String            @unique @map("coupon_id")
  ownerId         String            @map("owner_id")
  claimantId      String            @map("claimant_id")
  claimRequestId  String            @map("claim_request_id")
  transactionType   CouponType        @map("transaction_type")
  status            TransactionStatus @default(CREATED)
  ownerCompleted    Boolean           @default(false) @map("owner_completed")
  claimantCompleted Boolean           @default(false) @map("claimant_completed")
  completedAt       DateTime?         @map("completed_at")
  // Exchange escrow: claimant's offered barcode + simultaneous-reveal gate.
  offerBarcodeEncryptedData String?  @map("offer_barcode_encrypted_data")
  offerBarcodeMime          String?  @map("offer_barcode_mime")
  ownerReady                Boolean   @default(false) @map("owner_ready")
  claimantReady             Boolean   @default(false) @map("claimant_ready")
  revealedAt                DateTime? @map("revealed_at")
  disputedAt                DateTime? @map("disputed_at")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  coupon       Coupon               @relation(fields: [couponId], references: [id])
  owner        User                 @relation("OwnerTransactions", fields: [ownerId], references: [id])
  claimant     User                 @relation("ClaimantTransactions", fields: [claimantId], references: [id])
  claimRequest ClaimRequest         @relation(fields: [claimRequestId], references: [id])
  messages     TransactionMessage[]
  ratings      Rating[]
  reports      Report[]

  @@index([ownerId])
  @@index([claimantId])
  @@index([completedAt])
  @@map("transactions")
}

model TransactionMessage {
  id            String   @id @default(uuid())
  transactionId String   @map("transaction_id")
  senderId      String   @map("sender_id")
  message       String
  imageUrl      String?  @map("image_url")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  transaction Transaction @relation(fields: [transactionId], references: [id])
  sender      User        @relation(fields: [senderId], references: [id])

  @@index([transactionId])
  @@map("transaction_messages")
}

model Rating {
  id            String   @id @default(uuid())
  transactionId String   @map("transaction_id")
  fromUserId    String   @map("from_user_id")
  toUserId      String   @map("to_user_id")
  ratingScore   Int      @map("rating_score")
  tags          Json     @default("[]")
  comment       String?
  createdAt     DateTime @default(now()) @map("created_at")

  transaction Transaction @relation(fields: [transactionId], references: [id])
  fromUser    User        @relation("RatingsGiven", fields: [fromUserId], references: [id])
  toUser      User        @relation("RatingsReceived", fields: [toUserId], references: [id])

  @@unique([transactionId, fromUserId, toUserId])
  @@index([toUserId])
  @@map("ratings")
}

model Report {
  id               String       @id @default(uuid())
  reporterId       String       @map("reporter_id")
  couponId         String?      @map("coupon_id")
  transactionId    String?      @map("transaction_id")
  reportedUserId   String?      @map("reported_user_id")
  reason           ReportReason
  description      String?
  evidenceImageUrl String?      @map("evidence_image_url")
  status           ReportStatus @default(PENDING)
  adminNote        String?      @map("admin_note")
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")
  resolvedAt       DateTime?    @map("resolved_at")

  reporter     User         @relation("ReportsMade", fields: [reporterId], references: [id])
  reportedUser User?        @relation("ReportsAgainst", fields: [reportedUserId], references: [id])
  coupon       Coupon?      @relation(fields: [couponId], references: [id])
  transaction  Transaction? @relation(fields: [transactionId], references: [id])

  @@unique([reporterId, couponId])
  @@index([status])
  @@index([couponId])
  @@index([createdAt])
  @@map("reports")
}

model ScoreLedger {
  id            String             @id @default(uuid())
  userId        String             @map("user_id")
  eventType     ScoreEventType     @map("event_type")
  scoreDelta    Int                @map("score_delta")
  referenceType ScoreReferenceType @map("reference_type")
  referenceId   String             @map("reference_id")
  description   String?
  createdAt     DateTime           @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, eventType, referenceType, referenceId])
  @@index([userId])
  @@map("score_ledgers")
}

model Notification {
  id            String           @id @default(uuid())
  userId        String           @map("user_id")
  type          NotificationType
  title         String
  body          String
  referenceType String?          @map("reference_type")
  referenceId   String?          @map("reference_id")
  isRead        Boolean          @default(false) @map("is_read")
  createdAt     DateTime         @default(now()) @map("created_at")
  readAt        DateTime?        @map("read_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId, isRead])
  @@map("notifications")
}

model AuditLog {
  id         String   @id @default(uuid())
  actorId    String?  @map("actor_id")
  action     String
  targetType String   @map("target_type")
  targetId   String   @map("target_id")
  beforeValue Json?   @map("before_value")
  afterValue  Json?   @map("after_value")
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([targetType, targetId])
  // Hot path: applyQuota counts coupon.publish events per user on every /auth/me.
  @@index([actorId, action, createdAt])
  @@map("audit_logs")
}

model BrandFollow {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  brand     String
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, brand])
  @@index([brand])
  @@map("brand_follows")
}

model Appeal {
  id         String       @id @default(uuid())
  userId     String       @map("user_id")
  message    String
  status     AppealStatus @default(PENDING)
  adminNote  String?      @map("admin_note")
  createdAt  DateTime     @default(now()) @map("created_at")
  resolvedAt DateTime?    @map("resolved_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@map("appeals")
}

// 社群發文換申請次數：user posts about CouponShare (Threads etc. with #CouponShare),
// submits proof, admin reviews within 7 days. Approved → +10 monthly claim credits
// (+20 if the screenshot shows 100+ likes) and +5 contribution score. One per user
// per Taipei calendar month (enforced at submit).
model SocialPost {
  id            String           @id @default(uuid())
  userId        String           @map("user_id")
  topic         String
  postDate      DateTime         @map("post_date")
  // Proof — BOTH required: the public post link AND a screenshot (data-URI). The
  // admin reads the like count off the screenshot to pick the reward tier.
  postUrl       String           @map("post_url")
  evidenceImage String           @map("evidence_image")
  status        SocialPostStatus @default(PENDING)
  bonusGranted  Int?             @map("bonus_granted")
  adminNote     String?          @map("admin_note")
  createdAt     DateTime         @default(now()) @map("created_at")
  resolvedAt    DateTime?        @map("resolved_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([status])
  @@map("social_posts")
}

// Tiny key-value store for operational flags — e.g. the claim / register
// kill-switches an admin can flip during an abuse incident. Read through a short
// in-process cache (lib/settings) so the hot paths don't hit the DB every request.
model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("app_settings")
}

// IPs blocked from creating new accounts — captured from a user's recent activity
// when an admin suspends them, to stop the "make a fresh account and come back"
// evasion. Scoped to registration (not all traffic) to limit CGNAT collateral.
model BlockedIp {
  ip        String   @id
  userId    String?  @map("user_id")
  reason    String?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("blocked_ips")
}

// Precise DAU tracking: one row per (user, Taipei calendar day).
// Upserted by touchActivity() in lib/activity.ts (fire-and-forget).
// audit_logs covers historical data; this table gives precision going forward.
model DailyActive {
  userId String   @map("user_id")
  day    DateTime @db.Date @map("day")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([day, userId])
  @@index([userId])
  @@map("daily_actives")
}

// 企業合作窗口 — a business owner leaves contact info via the hidden /business
// form; the admin follows up by emailing a quote. No relation to User: leads are
// external people, usually not platform accounts.
model BusinessLead {
  id          String    @id @default(uuid())
  name        String
  email       String
  phone       String
  lineId      String    @map("line_id")
  // PENDING → CONTACTED (quote sent). Plain string keeps the manual prod
  // migration additive-trivial (no new PG enum type needed).
  status      String    @default("PENDING")
  createdAt   DateTime  @default(now()) @map("created_at")
  contactedAt DateTime? @map("contacted_at")

  @@index([status, createdAt])
  @@map("business_leads")
}

// ─── 企業官方福利券（GATED）───────────────────────────────────────────────
// Completely separate from user Coupon: multi-applicant, quota'd, brand-owned.
// Never queried by the user feed; the whole surface is behind the
// `brand_coupons_enabled` flag (default off) + admin. String status/mode fields
// keep the prod migration a trivial additive CREATE TABLE (no new PG enum type).

model Brand {
  id           String        @id @default(uuid())
  name         String
  logoText     String?       @map("logo_text")
  category     String?
  description  String?
  websiteUrl   String?       @map("website_url")
  contactName  String?       @map("contact_name")
  contactEmail String?       @map("contact_email")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  coupons BrandCoupon[]

  @@map("brands")
}

model BrandCoupon {
  id               String    @id @default(uuid())
  brandId          String    @map("brand_id")
  title            String
  description      String?
  category         String?
  redeemInfo       String?   @map("redeem_info")
  // DIRECT_CLAIM = tap to claim; MESSAGE_APPLICATION = leave a reason, admin approves.
  applicationMode  String    @default("DIRECT_CLAIM") @map("application_mode")
  maxApplications  Int       @default(100) @map("max_applications")
  maxPerUser       Int       @default(1) @map("max_per_user")
  applicationCount Int       @default(0) @map("application_count")
  viewCount        Int       @default(0) @map("view_count")
  clickCount       Int       @default(0) @map("click_count")
  ctaText          String?   @map("cta_text")
  ctaUrl           String?   @map("cta_url")
  startAt          DateTime? @map("start_at")
  endAt            DateTime? @map("end_at")
  usageExpiry      DateTime? @map("usage_expiry")
  // DRAFT | ACTIVE | PAUSED | ENDED
  status           String    @default("DRAFT")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  brand        Brand                    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  applications BrandCouponApplication[]

  @@index([brandId])
  @@index([status])
  @@map("brand_coupons")
}

model BrandCouponApplication {
  id            String    @id @default(uuid())
  brandCouponId String    @map("brand_coupon_id")
  // Plain scalar (no User relation) to keep this model self-contained.
  userId        String    @map("user_id")
  message       String?
  // PENDING | APPROVED | REJECTED | CLAIMED
  status        String    @default("PENDING")
  createdAt     DateTime  @default(now()) @map("created_at")
  decidedAt     DateTime? @map("decided_at")

  coupon BrandCoupon @relation(fields: [brandCouponId], references: [id], onDelete: Cascade)

  @@unique([brandCouponId, userId])
  @@index([brandCouponId, status])
  @@index([userId])
  @@map("brand_coupon_applications")
}
